# ══════════════════════════════════════════════════════════════════════════════
# Clinical Psychology Assistant — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Clinical Psychology Assistant"
APP_VERSION="0.1.0"
APP_ENV="development"           # development | staging | production
DEBUG=true
SECRET_KEY="change-me-to-a-long-random-secret-at-least-32-chars"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=1                   # increase to CPU count in production
API_RELOAD=true                 # set false in production

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_TIMEOUT=120              # seconds; increase for slow hardware
LLM_TEMPERATURE=0.1             # low temp for clinical accuracy
LLM_TOP_K=40
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL="BAAI/bge-large-en-v1.5"
EMBEDDING_DEVICE="cpu"          # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR="./data/chroma"
CHROMA_COLLECTION_NAME="clinical_knowledge_base"
CHROMA_DISTANCE_FUNCTION="cosine"

# ── RAG / Retrieval ───────────────────────────────────────────────────────────
RAG_TOP_K=10                    # docs retrieved before reranking
RAG_RERANK_TOP_K=4              # docs passed to LLM after reranking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_SIMILARITY_THRESHOLD=0.35   # minimum cosine similarity to include

# ── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_DATA_DIR="./data/raw"
INGESTION_PROCESSED_DIR="./data/processed"
INGESTION_BATCH_SIZE=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"               # json | console
LOG_FILE="./logs/app.log"
LOG_ROTATION="10 MB"
LOG_RETENTION="30 days"

# ── Security / Auth ───────────────────────────────────────────────────────────
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=30

# ── Database (optional — for session/audit storage) ───────────────────────────
# DATABASE_URL="sqlite:///./data/app.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/cpa_db"
